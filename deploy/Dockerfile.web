# Single image: static UI (nginx) + gateway on localhost:8081
# Build from repository root: docker build -f deploy/Dockerfile.web .

FROM node:20-bookworm AS ui
WORKDIR /ui
COPY ui/package.json ui/package-lock.json ./
RUN npm ci
COPY ui/ ./
RUN npm run build

FROM rust:1.79-bookworm AS rust
WORKDIR /app
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY engine ./engine
COPY risk ./risk
COPY md ./md
COPY gateway ./gateway
# Workspace members listed in root Cargo.toml — required for `cargo` to load the workspace
COPY tools ./tools
RUN cargo build --release -p gateway

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates nginx \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /etc/nginx/sites-enabled/default

COPY --from=rust /app/target/release/gateway /usr/local/bin/gateway
COPY markets_seed.json /etc/chronos/markets_seed.json
COPY --from=ui /ui/dist/ /usr/share/nginx/html/
COPY deploy/nginx.conf /etc/nginx/nginx.conf
COPY deploy/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV DATA_DIR=/data
ENV MARKETS_SEED=/etc/chronos/markets_seed.json
ENV RUST_LOG=info
# No synthetic seed on public demos unless you override
ENV CHRONOS_SEED_DUMMY_TRADES=0

EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
